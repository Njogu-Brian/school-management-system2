{
  "name": "@erp/admin",
  "version": "1.0.0",
  "description": "School ERP Admin App (management surface).",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "build:preview": "eas build --platform android --profile preview",
    "build:production": "eas build --platform android --profile production",
    "android:local": "expo run:android",
    "android:device": "expo run:android --device",
    "logs:android": "powershell -ExecutionPolicy Bypass -File ./scripts/capture-launch-logs.ps1",
    "icons:pad": "node ./scripts/pad-app-icons.mjs"
  },
  "dependencies": {
    "@erp/core": "*",
    "@erp/ui": "*",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.10.3",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/stack": "^7.3.3",
    "@tanstack/query-async-storage-persister": "^5.62.8",
    "@tanstack/react-query": "^5.62.8",
    "@tanstack/react-query-persist-client": "^5.62.8",
    "axios": "^1.6.5",
    "expo": "~54.0.35",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.10",
    "sharp": "^0.35.3",
    "typescript": "^5.3.3"
  }
