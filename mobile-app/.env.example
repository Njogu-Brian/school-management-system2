# API — must use EXPO_PUBLIC_* (embedded at build time). Rebuild native app after changing.
EXPO_PUBLIC_API_BASE_URL=https://erp.royalkingsschools.sc.ke/api
EXPO_PUBLIC_WEB_BASE_URL=https://erp.royalkingsschools.sc.ke
API_TIMEOUT=30000

# Pusher Configuration (for real-time notifications)
PUSHER_APP_KEY=your_pusher_key_here
PUSHER_CLUSTER=mt1

# App Configuration
APP_NAME=School ERP
APP_ENV=development

# Do not set EXPO_PUBLIC_UPDATES_ENABLED here. OTA is enabled only in EAS Build (see eas.json).
# After each release build, publish JS: npm run eas:update:preview (or eas:update:production).
