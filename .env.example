APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# HTTPS URL to the latest Android APK (S3/CloudFront). Shown on web login + mobile app branding API.
# Use a stable URL and overwrite the object each release, e.g. https://cdn.example.com/erp/RoyalKingsERP-latest.apk
MOBILE_APP_DOWNLOAD_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (optional - for object storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Use S3 for file storage (set when using S3)
# FILESYSTEM_PUBLIC_DISK=public
# FILESYSTEM_PRIVATE_DISK=private
# Or for S3:
# FILESYSTEM_PUBLIC_DISK=s3_public
# FILESYSTEM_PRIVATE_DISK=s3_private

# Local database dumps (Settings → Backup). Optional: custom folder on disk.
# BACKUP_STORAGE_PATH=
# Delete .sql/.zip backups older than this many days (scheduled + after each backup).
BACKUP_RETENTION_DAYS=5

# Database backups → S3 (recommended)
BACKUP_UPLOAD_TO_S3=true
BACKUP_S3_DISK=s3_private
BACKUP_S3_PREFIX=backups/mysql

# When running hourly backups, keep only latest N locally (0 disables).
BACKUP_KEEP_LOCAL_LATEST=2

VITE_APP_NAME="${APP_NAME}"

# Google Sheets – Fee / Income sync (see docs/GOOGLE_SHEETS_FEE_SYNC_DESIGN.md)
# GOOGLE_SHEETS_SYNC_ENABLED=false
# GOOGLE_SHEETS_CREDENTIALS_PATH=storage/app/google-sheets-credentials.json
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_INCOME_RANGE=Income!A2:H500
# GOOGLE_SHEETS_COL_ADMISSION=0
# GOOGLE_SHEETS_COL_NAME=1
# GOOGLE_SHEETS_COL_VOTEHEAD=2
# GOOGLE_SHEETS_COL_INVOICED=3
# GOOGLE_SHEETS_COL_PAID=4
# GOOGLE_SHEETS_COL_BALANCE=5
# GOOGLE_SHEETS_COL_TERM=6
# GOOGLE_SHEETS_COL_YEAR=7

# Expo push (optional; higher rate limits) — https://expo.dev/accounts/[account]/settings/access-tokens
# EXPO_ACCESS_TOKEN=
